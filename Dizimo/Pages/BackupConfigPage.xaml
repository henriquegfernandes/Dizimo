<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Dizimo.Pages.BackupConfigPage"
             Title="Configuração de Backup">
    <VerticalStackLayout Padding="20" Spacing="20">
        <Button Text="Escolher Pasta de Backup" Command="{Binding EscolherPastaCommand}" />
        <Label Text="Pasta atual:" FontSize="14" />
        <Label Text="{Binding BackupFolderPath}" FontSize="14" />
        <Button Text="Backup para Pasta" Command="{Binding BackupCommand}" />
        <Button Text="Restaurar da Pasta" Command="{Binding RestoreCommand}" />
    </VerticalStackLayout>
</ContentPage>
