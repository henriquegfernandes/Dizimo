<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Dizimo.Pages.RelatorioGeralPage"
             Title="Relatório Geral">
  <ContentPage.Content>
    <StackLayout Padding="8">
      <Label Text="Relatório Geral" FontAttributes="Bold" FontSize="18" HorizontalOptions="Center" />
      <CollectionView ItemsSource="{Binding Items}">
      <CollectionView.ItemTemplate>
        <DataTemplate>
          <Grid Padding="8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Label Text="{Binding Nome}" />
            <Label Grid.Column="1" Text="{Binding Count}" HorizontalOptions="End" />
            <Label Grid.Column="2" Text="{Binding Total}" HorizontalOptions="End" />
          </Grid>
        </DataTemplate>
      </CollectionView.ItemTemplate>
    </CollectionView>
      <Label Text="{Binding TotalGeral, StringFormat='Total Geral: {0:C}'}" HorizontalOptions="End" FontAttributes="Bold" />
    </StackLayout>
  </ContentPage.Content>
</ContentPage>
