<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Dizimo.Pages.RelatorioOfertasPage"
             Title="Ofertas por Data">
  <ContentPage.Content>
    <StackLayout Padding="12">
      <DatePicker Date="{Binding Data}" />
      <Button Text="Filtrar" Command="{Binding FiltrarCommand}" />
      <CollectionView ItemsSource="{Binding Items}">
        <CollectionView.ItemTemplate>
          <DataTemplate>
            <Grid Padding="8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <Label Text="{Binding Observacao}" />
              <Label Grid.Column="1" Text="{Binding Valor, StringFormat='{}{0:C}'}" HorizontalOptions="End" />
            </Grid>
          </DataTemplate>
        </CollectionView.ItemTemplate>
      </CollectionView>
      <Label Text="{Binding TotalOfertas, StringFormat='Total: {0:C}'}" HorizontalOptions="End" FontAttributes="Bold" />
    </StackLayout>
  </ContentPage.Content>
</ContentPage>
