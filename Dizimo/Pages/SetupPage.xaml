<?xml version="1.0" encoding="UTF-8" ?>
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Dizimo.ViewModels"
             x:Class="Dizimo.Pages.SetupPage"
             x:DataType="vm:SetupViewModel">
    
    <UserControl.Resources>
    </UserControl.Resources>

    <StackPanel Margin="16" VerticalAlignment="Center" Spacing="10" Width="500" HorizontalAlignment="Center">
        
        <Image Source="avares://Dizimo/Resources/Images/dizimologo.png" 
               Height="240" Width="240" 
               HorizontalAlignment="Center" />

        <!-- Título -->
        <TextBlock 
            Text="Bem-vindo!" 
            FontSize="28" 
            FontWeight="Bold"
            HorizontalAlignment="Center"
            Foreground="{DynamicResource BrushPrimary}" />

        <TextBlock 
            Text="Crie seu primeiro usuário administrador para começar" 
            FontSize="14"
            HorizontalAlignment="Center"
            Foreground="{DynamicResource BrushTextSecondary}"
            Opacity="0.7"
            TextAlignment="Center" />

        <!-- Nome de Usuário -->
        <StackPanel Spacing="5" Margin="0,15,0,0">
            <TextBlock 
                Text="Nome de Usuário" 
                FontSize="12" 
                FontWeight="Bold" />

            <TextBox 
                PlaceholderText="Usuário" 
                Text="{Binding NomeUsuario}"
                Background="{DynamicResource BrushBackgroundPrimary}"
                Foreground="{DynamicResource BrushTextPrimary}"
                BorderBrush="{DynamicResource BrushBorder}"
                BorderThickness="1"
                Padding="10"
                Height="40" />
        </StackPanel>

        <!-- Senha -->
        <StackPanel Spacing="5" Margin="0,15,0,0">
            <TextBlock 
                Text="Senha" 
                FontSize="12" 
                FontWeight="Bold" />
            
            <TextBox 
                x:Name="SenhaTextBox"
                PlaceholderText="Digite uma senha"
                Text="{Binding Senha}"
                PasswordChar="*"
                Background="{DynamicResource BrushBackgroundPrimary}"
                Foreground="{DynamicResource BrushTextPrimary}"
                BorderBrush="{DynamicResource BrushBorder}"
                BorderThickness="1"
                Padding="10"
                Height="40"
                KeyDown="OnSenhaKeyDown" />
            
            <TextBlock 
                Text="Mínimo 6 caracteres" 
                FontSize="11"
                Opacity="0.6" />
        </StackPanel>

        <!-- Confirmação de Senha -->
        <StackPanel Spacing="5" Margin="0,15,0,0">
            <TextBlock 
                Text="Confirmar Senha" 
                FontSize="12" 
                FontWeight="Bold" />
            
            <TextBox 
                x:Name="SenhaConfirmacaoTextBox"
                PlaceholderText="Confirme a senha"
                Text="{Binding SenhaConfirmacao}"
                PasswordChar="*"
                Background="{DynamicResource BrushBackgroundPrimary}"
                Foreground="{DynamicResource BrushTextPrimary}"
                BorderBrush="{DynamicResource BrushBorder}"
                BorderThickness="1"
                Padding="10"
                Height="40"
                KeyDown="OnSenhaConfirmacaoKeyDown" />
        </StackPanel>

        <!-- Mensagem de Erro -->
        <TextBlock 
            Text="{Binding MensagemErro}"
            Foreground="{StaticResource ColorError}"
            FontSize="12"
            HorizontalAlignment="Center"
            Margin="0,8"
            TextAlignment="Center"
            IsVisible="{Binding MensagemErro, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

        <!-- Espaço -->
        <Border Height="12" Background="Transparent" />

        <!-- Botão Criar Usuário -->
        <Button Classes="Primary"
            Content="Criar Usuário"
            Command="{Binding CriarPrimeiroUsuarioCommand}"
            IsEnabled="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}"
            Padding="12"
            Height="40"
            FontSize="14"
            FontWeight="Bold" />

        <!-- Indicador de Carregamento -->
        <ProgressBar 
            IsVisible="{Binding IsLoading}"
            IsIndeterminate="True"
            Margin="0,10,0,0"
            Height="3" />
    </StackPanel>
</UserControl>
