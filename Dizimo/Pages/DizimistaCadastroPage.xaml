<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Dizimo.ViewModels"
             xmlns:sf="clr-namespace:Syncfusion.Maui.Toolkit.TextInputLayout;assembly=Syncfusion.Maui.Toolkit"
             xmlns:controls="clr-namespace:Dizimo.Pages.Controls"
             xmlns:fonts="clr-namespace:Fonts"
             x:Class="Dizimo.Pages.DizimistaCadastroPage">
    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="{StaticResource LayoutPadding}" Spacing="{StaticResource LayoutSpacing}">
                <sf:SfTextInputLayout Hint="Nºmero de Cadastro" >
                    <Entry Placeholder="Nºmero Cadastro" Keyboard="Numeric" Text="{Binding NumeroCadastro}"/>
                </sf:SfTextInputLayout>
                <sf:SfTextInputLayout Hint="Nome" >
                    <Entry Text="{Binding Nome}" SemanticProperties.Description="Name"/>
                </sf:SfTextInputLayout>
                <DatePicker Date="{Binding DataNascimento}"/>
                <Switch IsToggled="{Binding Ativo}" />
                <Button Text="Salvar" Command="{Binding SalvarCommand}" />
           </VerticalStackLayout>
       </ScrollView>
    </Grid>
</ContentPage>
