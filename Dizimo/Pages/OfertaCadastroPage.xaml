<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Dizimo.ViewModels"
             xmlns:sf="clr-namespace:Syncfusion.Maui.Toolkit.TextInputLayout;assembly=Syncfusion.Maui.Toolkit"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2021/maui/toolkit"
             xmlns:fonts="clr-namespace:Fonts"
             xmlns:local="clr-namespace:Dizimo.Converters"
             x:Class="Dizimo.Pages.OfertaCadastroPage"
             Title="">
    <ContentPage.Resources>
        <ResourceDictionary>
            <local:InvertedBoolConverter x:Key="InvertedBoolConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>
    <Grid RowDefinitions="Auto,*">
        <!-- Barra de navegação customizada -->
        <Grid Grid.Row="0" Padding="16,12" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
            <!-- Botão de voltar -->
            <Button Grid.Column="0" 
                    Text="Voltar"
                    ImageSource="{StaticResource IconLeftArrow}"
                    Clicked="OnBackButtonClicked"
                    Style="{StaticResource NavButtonStyle}"
                    Padding="12"
                    HorizontalOptions="Start"
                    VerticalOptions="Center" />
            
            <!-- Título centralizado -->
            <Label Grid.Column="1" 
                   Text="Cadastro de Oferta" 
                   FontSize="20"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   VerticalOptions="Center" />
            
            <!-- Botão de excluir à direita (visível apenas em modo edição) -->
            <Button Grid.Column="2"
                    Text="Excluir"
                    ImageSource="{StaticResource IconDelete}"
                    Command="{Binding ExcluirCommand}"
                    IsVisible="{Binding IsEditMode}"
                    Style="{StaticResource NavButtonStyle}"
                    Padding="12"
                    HorizontalOptions="End"
                    VerticalOptions="Center" />

            <!-- Radio Buttons para mês único ou range (visível apenas em modo criação) -->
            <StackLayout Grid.Row="1" Grid.Column="3" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="16" VerticalOptions="Center" HorizontalOptions="Center" Padding="12,0" IsVisible="{Binding IsEditMode, Converter={StaticResource InvertedBoolConverter}}">
                <RadioButton Content="Mês único" 
                 Value="false"
                 GroupName="TipoMes"
                 IsChecked="{Binding UsarRangoMeses, Converter={StaticResource InvertedBoolConverter}}"
                 FontSize="12" />
                <RadioButton Content="Vários meses" 
                 Value="true"
                 GroupName="TipoMes"
                 IsChecked="{Binding UsarRangoMeses}"
                 FontSize="12" />
            </StackLayout>
            
        </Grid>

        <!-- Conteúdo da página -->
        <ScrollView Grid.Row="1" Padding="16,12">
            <Grid Padding="0" RowSpacing="12" ColumnSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="2*" />
					<ColumnDefinition Width="2*" />
					<ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="2*" />
                </Grid.ColumnDefinitions>
                
                <!-- Código do Dizimista com Busca Automática -->
                <sf:SfTextInputLayout Grid.Row="0" Grid.Column="0" Hint="Código do Dizimista">
                    <Entry Placeholder="Digite o código" 
                           Keyboard="Numeric" 
                           Text="{Binding CodigoDizimista}"
                           Unfocused="OnCodigoDizimistaUnfocused" />
                </sf:SfTextInputLayout>
                
                <!-- Nome do Dizimista (somente leitura) -->
                <sf:SfTextInputLayout Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="5" Hint="Dizimista">
                    <Entry Text="{Binding NomeDizimista}" 
                           IsReadOnly="True"
                           BackgroundColor="#F0F0F0"
                           TextColor="#666666" />
                </sf:SfTextInputLayout>

                <!-- Data -->
                <sf:SfTextInputLayout Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Hint="Data">
                    <DatePicker Date="{Binding DataOferta}" Format="dd/MM/yyyy" />
                </sf:SfTextInputLayout>

                <!-- Valor -->
                <sf:SfTextInputLayout Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2" Hint="Valor">
                    <Entry Placeholder="0,00" 
                           Keyboard="Numeric" 
                           Text="{Binding Valor}" />
                </sf:SfTextInputLayout>
                
                <!-- Tipo de Pagamento -->
                <sf:SfTextInputLayout Grid.Row="1" Grid.Column="4" Grid.ColumnSpan="2" Hint="Tipo de Pagamento">
                    <Picker ItemsSource="{Binding TiposPagamentoCollection}" 
                            SelectedItem="{Binding TipoPagamento}" />
                </sf:SfTextInputLayout>

                <!-- Mês de Referência (único) -->
                <sf:SfTextInputLayout Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Hint="Mês de Referência" IsVisible="{Binding UsarRangoMeses, Converter={StaticResource InvertedBoolConverter}}">
                    <Picker ItemsSource="{Binding MesesNomesCollection}" 
                            SelectedItem="{Binding MesNomeAtual, Mode=TwoWay}" />
                </sf:SfTextInputLayout>

                <!-- Ano de Referência (único) -->
                <sf:SfTextInputLayout Grid.Row="2" Grid.Column="2" Hint="Ano de Referência" IsVisible="{Binding UsarRangoMeses, Converter={StaticResource InvertedBoolConverter}}">
                    <Picker ItemsSource="{Binding AnosCollection}" SelectedItem="{Binding AnoSelecionado, Mode=TwoWay}" />
                </sf:SfTextInputLayout>

                <!-- Mês de Referência (início) para range -->
                <sf:SfTextInputLayout Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Hint="Mês Início" IsVisible="{Binding UsarRangoMeses}">
                    <Picker ItemsSource="{Binding MesesNomesCollection}" 
                            SelectedItem="{Binding MesNomeAtual, Mode=TwoWay}" />
                </sf:SfTextInputLayout>

                <!-- Ano de Referência (início) para range -->
                <sf:SfTextInputLayout Grid.Row="2" Grid.Column="2" Hint="Ano Início" IsVisible="{Binding UsarRangoMeses}">
                    <Picker ItemsSource="{Binding AnosCollection}" SelectedItem="{Binding AnoSelecionado, Mode=TwoWay}" />
                </sf:SfTextInputLayout>

                <!-- Mês de Referência (fim) para range -->
                <sf:SfTextInputLayout Grid.Row="2" Grid.Column="3" Grid.ColumnSpan="2" Hint="Mês Fim" IsVisible="{Binding UsarRangoMeses}">
                    <Picker ItemsSource="{Binding MesesNomesCollection}" 
                            SelectedItem="{Binding MesNomeAtualFim, Mode=TwoWay}" />
                </sf:SfTextInputLayout>

                <!-- Ano de Referência (fim) para range -->
                <sf:SfTextInputLayout Grid.Row="2" Grid.Column="5" Hint="Ano Fim" IsVisible="{Binding UsarRangoMeses}">
                    <Picker ItemsSource="{Binding AnosCollection}" SelectedItem="{Binding AnoSelecionadoFim, Mode=TwoWay}" />
                </sf:SfTextInputLayout>

                <!-- Espaço filler -->
                <StackLayout Grid.Row="2" Grid.Column="4" IsVisible="{Binding UsarRangoMeses, Converter={StaticResource InvertedBoolConverter}}" />

                <!-- Botão Salvar -->
                <Button Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="4" 
                        Text="Salvar" 
                        Command="{Binding SalvarCommand}" 
                        IsEnabled="{Binding DizimistaAtivo}"
                        Margin="0,12,0,0" />
            </Grid>
        </ScrollView>
    </Grid>
</ContentPage>
