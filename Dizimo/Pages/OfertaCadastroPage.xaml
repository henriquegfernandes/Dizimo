<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Dizimo.ViewModels"
             x:Class="Dizimo.Pages.OfertaCadastroPage">
    <ContentPage.BindingContext>
        <vm:OfertaCadastroViewModel />
    </ContentPage.BindingContext>
    <StackLayout Padding="16">
        <Label Text="Cadastro de Oferta" FontSize="24" HorizontalOptions="Center" />
        <Picker Title="Dizimista" ItemsSource="{Binding Dizimistas}" ItemDisplayBinding="{Binding Nome}" SelectedItem="{Binding DizimistaId, Mode=TwoWay}" />
        <Entry Placeholder="Valor" Keyboard="Numeric" Text="{Binding Valor}" />
        <DatePicker Date="{Binding Data}" />
        <Button Text="Salvar" Command="{Binding SalvarCommand}" />
    </StackLayout>
</ContentPage>
