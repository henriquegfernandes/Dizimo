<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Dizimo.ViewModels"
             x:Class="Dizimo.Pages.UsuarioListPage">
    <StackLayout Spacing="12" Padding="16">
        <Label Text="Usuários" FontSize="24" HorizontalOptions="Center" />
        <CollectionView ItemsSource="{Binding Usuarios}" SelectionMode="Single" SelectedItem="{Binding SelectedUsuario, Mode=TwoWay}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <StackLayout Orientation="Horizontal" Padding="8">
                        <Label Text="{Binding Nome}" WidthRequest="150" />
                        <Label Text="{Binding Login}" WidthRequest="120" />
                        <Label Text="{Binding Perfil}" WidthRequest="80" />
                        <Label Text="{Binding Ativo, StringFormat='Ativo: {0}'}" WidthRequest="80" />
                    </StackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        <Entry Placeholder="Nome" Text="{Binding Nome}" />
        <Entry Placeholder="Login" Text="{Binding Login}" />
        <Entry Placeholder="Senha" IsPassword="True" Text="{Binding Senha}" />
        <Switch IsToggled="{Binding Ativo}" />
        <Button Text="Salvar" Command="{Binding SalvarCommand}" />
        <Button Text="Editar Selecionado" Command="{Binding EditarUsuarioCommand}" IsEnabled="{Binding SelectedUsuario, Converter={StaticResource NullToBoolConverter}}" />
        <Button Text="Excluir Selecionado" Command="{Binding ExcluirUsuarioCommand}" IsEnabled="{Binding SelectedUsuario, Converter={StaticResource NullToBoolConverter}}" />
        <Button Text="Inativar Selecionado" Command="{Binding InativarUsuarioCommand}" IsEnabled="{Binding SelectedUsuario, Converter={StaticResource NullToBoolConverter}}" />
    </StackLayout>
</ContentPage>
