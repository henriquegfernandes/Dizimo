<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Dizimo.Pages.LoginPage"
             Title="Login">
  <ContentPage.Content>
    <StackLayout Padding="24" Spacing="12">
      <Entry Placeholder="Usuário" Text="{Binding Username}" />
      <Entry Placeholder="Senha" IsPassword="True" Text="{Binding Password}" />
      <Button Text="Entrar" Command="{Binding LoginCommand}" />
    </StackLayout>
  </ContentPage.Content>
</ContentPage>
