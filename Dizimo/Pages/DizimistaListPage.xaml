<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Dizimo.ViewModels"
             xmlns:local="clr-namespace:Dizimo.Converters"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2021/maui/toolkit"
             xmlns:fonts="clr-namespace:Dizimo.Resources.Fonts"
             x:Class="Dizimo.Pages.DizimistaListPage">
    <ContentPage.Resources>
        <ResourceDictionary>
            <local:NullToBoolConverter x:Key="NullToBoolConverter" />
            <local:GreaterThanZeroToBoolConverter x:Key="GreaterThanZeroToBoolConverter" />
            <local:AtivoToStatusConverter x:Key="AtivoToStatusConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>
    <Grid>
        <ScrollView>
            <VerticalStackLayout Spacing="{StaticResource LayoutSpacing}" Padding="{StaticResource LayoutPadding}">
                <StackLayout Padding="16" Spacing="12">
                    <!-- Filtro unificado -->
                    <Grid ColumnSpacing="{StaticResource LayoutSpacing}" ColumnDefinitions="Auto,*,Auto,Auto">
                        <Picker ItemsSource="{Binding StatusOptions}" 
                                SelectedItem="{Binding StatusSelecionado}"
                                Grid.Column="0"
                                BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#222228}"/>
                        <Entry Placeholder="Buscar por nome ou número" 
                               Text="{Binding FiltroNome}" 
                               Grid.Column="1"
                               BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#222228}"
                               Completed="OnFiltroCompleted" />
                        <Button Grid.Column="2"
                                Command="{Binding AplicarFiltrosCommand}" 
                                Padding="12"
                                VerticalOptions="Center"
                                HorizontalOptions="Center"
                                ImageSource="{StaticResource IconSearch}"
                                ToolTipProperties.Text="Filtrar"
                                CornerRadius="6" />
                        <Button Grid.Column="3"
                                Command="{Binding LimparFiltrosCommand}" 
                                Padding="12"
                                VerticalOptions="Center"
                                HorizontalOptions="Center"
                                ImageSource="{StaticResource IconClean}"
                                ToolTipProperties.Text="Limpar Filtros"
                                CornerRadius="6" />
                    </Grid>
                    <!-- Linha de botões de exportação/impressão -->
                    <Grid ColumnSpacing="{StaticResource LayoutSpacing}" ColumnDefinitions="*,*">
                        <Button Text="Exportar"
                                Command="{Binding ExportarCommand}" 
                                ImageSource="{StaticResource IconExport}" 
                                ToolTipProperties.Text="Exportar em Excel" 
                                CornerRadius="8"
                                Padding="10"
                                Grid.Column="0"
                                HorizontalOptions="Center"
                                VerticalOptions="Center" />
                        <Button Text="Imprimir"
                                Command="{Binding ImprimirCommand}" 
                                ImageSource="{StaticResource IconPrint}" 
                                ToolTipProperties.Text="Imprimir em HTML"
                                CornerRadius="8"
                                Padding="10"
                                Grid.Column="1"
                                HorizontalOptions="Center"
                                VerticalOptions="Center" />
                    </Grid>
                    <!-- Linha de título da lista -->
                    <Grid ColumnSpacing="{StaticResource LayoutSpacing}" ColumnDefinitions="1*,2*,3*,2*,1*,1*" Padding="8">
                        <Label Text="" Grid.Column="0" />
                        <Label Text="Nº Cadastro" Grid.Column="1" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                        <Label Text="Nome" Grid.Column="2" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                        <Label Text="Nascimento" Grid.Column="3" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                        <Label Text="Status" Grid.Column="4" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                        <Label Text="" Grid.Column="5" />
                    </Grid>
                    <!-- Lista paginada com infinite scroll e animação -->
                    <CollectionView x:Name="DizimistasCollectionView"
                                    ItemsSource="{Binding Dizimistas}"
                                    RemainingItemsThreshold="5"
                                    RemainingItemsThresholdReachedCommand="{Binding CarregarMaisDizimistasCommand}"
                                    SelectionMode="Multiple"
                                    SelectionChanged="OnSelectionChanged"
                                    Margin="0,0,0,8">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="{StaticResource LayoutSpacing}" ColumnDefinitions="1*,2*,3*,2*,1*,1*" Padding="8">
                                    <Label Text="{Binding NumeroCadastro}" Grid.Column="1" HorizontalTextAlignment="Center" />
                                    <Label Text="{Binding Nome}" Grid.Column="2" HorizontalTextAlignment="Center" />
                                    <Label Text="{Binding DataNascimento, StringFormat='{0:dd/MM/yyyy}'}" Grid.Column="3" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="4" Text="{Binding Ativo, Converter={StaticResource AtivoToStatusConverter}}" HorizontalTextAlignment="Center" />
                                    <Button Grid.Column="5"
                                            Clicked="OnVerDetalhesDizimistaClicked"
                                            CommandParameter="{Binding .}"
                                            ImageSource="{StaticResource IconEye}"
                                            Padding="0"
                                            CornerRadius="6"
                                            HorizontalOptions="Center"
                                            VerticalOptions="Center"/>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <!-- Linha de resultados -->
                    <Label Text="{Binding TextoResultados}" 
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"
                           FontAttributes="Bold"
                           Margin="0,8" />

                    <!-- Botão Carregar Mais -->
                    <Button Text="Carregar Mais" 
                            Command="{Binding CarregarMaisDizimistasCommand}"
                            IsVisible="{Binding TemProxima}"
                            Margin="0,12,0,8"
                            Padding="12"
                            HorizontalOptions="Center" />

                </StackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Botões flutuantes de ação em massa (excluir, ativar/inativar, selecionar todos) - Centralizados -->
        <Grid ColumnSpacing="12" ColumnDefinitions="*,*,*" Padding="12" VerticalOptions="End" HorizontalOptions="Center" IsVisible="{Binding DizimistasSelecionados.Count, Converter={StaticResource GreaterThanZeroToBoolConverter}}" Margin="0,0,0,24">
            <Button Text="Selecionar todos"
                    Clicked="OnSelecionarTodosClicked"
                    Padding="12"
                    CornerRadius="8"
                    Grid.Column="0"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    ImageSource="{StaticResource IconSelect}"/>

            <Button Text="Excluir" 
                    Command="{Binding ExcluirDizimistasSelecionadosCommand}" 
                    Padding="12"
                    CornerRadius="8"
                    Grid.Column="1"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    ImageSource="{StaticResource IconDelete}"/>

            <Button Text="Ativar/Inativar" 
                    Command="{Binding InativarDizimistasSelecionadosCommand}" 
                    Padding="12"
                    CornerRadius="8"
                    Grid.Column="2"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    ImageSource="{StaticResource IconSwitch}"/>
        </Grid>

        <!-- Botão flutuante de adicionar dizimista -->
        <Button
            Command="{Binding NovoDizimistaCommand}"
            Clicked="OnNovoDizimistaClicked"
            IsEnabled="True"
            ImageSource="{StaticResource IconAdd}"
            CornerRadius="28"
            Padding="0"
            HeightRequest="56"
            WidthRequest="56"
            VerticalOptions="End"
            HorizontalOptions="End"
            Margin="24"
            BackgroundColor="{DynamicResource Primary}"
            TextColor="White"
            FontSize="28"
            SemanticProperties.Description="Adicionar dizimista" />
    </Grid>
</ContentPage>
