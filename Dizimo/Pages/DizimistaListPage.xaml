<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Dizimo.Pages.DizimistaListPage"
             Title="Dizimistas">
    <ContentPage.Content>
        <StackLayout Padding="12">
            <SearchBar x:Name="SearchBar" Placeholder="Pesquisar por nome ou código" />
            <CollectionView x:Name="CollectionView" ItemsSource="{Binding Dizimistas}" SelectionChanged="CollectionView_SelectionChanged">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Padding="10" Margin="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Label Text="{Binding Nome}" FontSize="16" />
                                <Label Grid.Column="1" Text="{Binding Codigo}" FontSize="14" HorizontalOptions="End" />
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
            <Grid ColumnDefinitions="*,*,*">
                <Button Text="Novo Dizimista" HorizontalOptions="Center" Grid.Column="0" Command="{Binding NewCommand}" />
                <Button Text="Exportar Backup" HorizontalOptions="Center" Grid.Column="1" Command="{Binding ExportCommand}" />
                <Button Text="Importar Backup" HorizontalOptions="Center" Grid.Column="2" Command="{Binding ImportCommand}" />
            </Grid>
        </StackLayout>
    </ContentPage.Content>
</ContentPage>
