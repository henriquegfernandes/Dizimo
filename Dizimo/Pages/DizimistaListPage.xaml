<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Dizimo.ViewModels"
             xmlns:local="clr-namespace:Dizimo.Converters"
             x:Class="Dizimo.Pages.DizimistaListPage">
    <ContentPage.Resources>
        <ResourceDictionary>
            <local:NullToBoolConverter x:Key="NullToBoolConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>
    <ScrollView>
        <VerticalStackLayout Spacing="{StaticResource LayoutSpacing}" Padding="{StaticResource LayoutPadding}">
            <Label Text="Dizimistas" FontSize="24" HorizontalOptions="Center" />
            <Grid ColumnSpacing="{StaticResource LayoutSpacing}" ColumnDefinitions="4*,4*,2*">
                <Entry Placeholder="Buscar por nome" Text="{Binding FiltroNome}" Grid.Column="0"/>
                <Entry Placeholder="Buscar por número" Text="{Binding FiltroNumeroCadastro}" Keyboard="Numeric" Grid.Column="1"/>
                <Button Text="Filtrar" Command="{Binding AplicarFiltrosCommand}" Grid.Column="2">
                    <Button.ImageSource>
                        <FontImageSource Glyph="&#xF002;" FontFamily="FontAwesome" Color="{DynamicResource ButtonIconColor}" />
                    </Button.ImageSource>
                </Button>
            </Grid>
            <CollectionView ItemsSource="{Binding Dizimistas}" SelectionMode="Multiple" SelectedItems="{Binding DizimistasSelecionados, Mode=TwoWay}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnSpacing="{StaticResource LayoutSpacing}" ColumnDefinitions="Auto,2*,4*,2*,2*">
                            <CheckBox IsChecked="{Binding IsSelecionado, Mode=TwoWay}" Grid.Column="0" />
                            <Label Text="{Binding NumeroCadastro}" WidthRequest="60" Grid.Column="1" />
                            <Label Text="{Binding Nome}" WidthRequest="200" Grid.Column="2" />
                            <Label Text="{Binding DataNascimento, StringFormat='dd/MM/yyyy'}" WidthRequest="100" Grid.Column="3" />
                            <Label Text="{Binding Ativo, StringFormat='Ativo: {0}'}" WidthRequest="80" Grid.Column="4"/>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
            <Button Text="Carregar" Command="{Binding CarregarDizimistasCommand}">
                <Button.ImageSource>
                    <FontImageSource Glyph="&#xF021;" FontFamily="FontAwesome" Color="{DynamicResource ButtonIconColor}" />
                </Button.ImageSource>
            </Button>
            <Button Text="+ Novo Dizimista" Clicked="OnNovoDizimistaClicked">
                <Button.ImageSource>
                    <FontImageSource Glyph="+" FontFamily="FontAwesome" Color="{DynamicResource ButtonIconColor}" />
                </Button.ImageSource>
            </Button>
            <StackLayout Orientation="Horizontal" Padding="8" Spacing="16">
                <Button Text="Editar Selecionado" Command="{Binding EditarDizimistaCommand}" IsEnabled="{Binding DizimistasSelecionados.Count, Converter={StaticResource NullToBoolConverter}}">
                    <Button.ImageSource>
                        <FontImageSource Glyph="&#xF044;" FontFamily="FontAwesome" Color="{DynamicResource ButtonIconColor}" />
                    </Button.ImageSource>
                </Button>
                <Button Text="Excluir Selecionado" Command="{Binding ExcluirDizimistaCommand}" IsVisible="{Binding DizimistasSelecionados.Count, Converter={StaticResource NullToBoolConverter}}">
                    <Button.ImageSource>
                        <FontImageSource Glyph="&#xF1F8;" FontFamily="FontAwesome" Color="{DynamicResource ButtonIconColor}" />
                    </Button.ImageSource>
                </Button>
                <Button Text="Inativar Selecionado" Command="{Binding InativarDizimistaCommand}" IsVisible="{Binding DizimistasSelecionados.Count, Converter={StaticResource NullToBoolConverter}}">
                    <Button.ImageSource>
                        <FontImageSource Glyph="&#xF070;" FontFamily="FontAwesome" Color="{DynamicResource ButtonIconColor}" />
                    </Button.ImageSource>
                </Button>
            </StackLayout>
            <Button Text="Exportar CSV" Command="{Binding ExportarCommand}">
                <Button.ImageSource>
                    <FontImageSource Glyph="&#xF56E;" FontFamily="FontAwesome" Color="{DynamicResource ButtonIconColor}" />
                </Button.ImageSource>
            </Button>
            <Button Text="Importar CSV" Command="{Binding ImportarCommand}">
                <Button.ImageSource>
                    <FontImageSource Glyph="&#xF574;" FontFamily="FontAwesome" Color="{DynamicResource ButtonIconColor}" />
                </Button.ImageSource>
            </Button>
            <Button Text="Baixar Modelo CSV" Command="{Binding BaixarModeloCommand}">
                <Button.ImageSource>
                    <FontImageSource Glyph="&#xF019;" FontFamily="FontAwesome" Color="{DynamicResource ButtonIconColor}" />
                </Button.ImageSource>
            </Button>
            <StackLayout Orientation="Horizontal" Padding="8">
                <Label Text="Mês aniversário:" />
                <Entry Placeholder="Mês" Text="{Binding FiltroMesAniversario}" WidthRequest="60" Keyboard="Numeric" />
                <Button Text="Relatório Aniversariantes" Command="{Binding GerarRelatorioAniversariantesCommand}">
                    <Button.ImageSource>
                        <FontImageSource Glyph="&#xF073;" FontFamily="FontAwesome" Color="{DynamicResource ButtonIconColor}" />
                    </Button.ImageSource>
                </Button>
            </StackLayout>
            <CollectionView ItemsSource="{Binding Aniversariantes}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <StackLayout Orientation="Horizontal" Padding="8">
                            <Label Text="{Binding NumeroCadastro}" WidthRequest="60" />
                            <Label Text="{Binding Nome}" WidthRequest="200" />
                            <Label Text="{Binding DataNascimento, StringFormat='dd/MM/yyyy'}" WidthRequest="100" />
                        </StackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
            <Button Text="Relatório Geral" Command="{Binding GerarRelatorioGeralCommand}">
                <Button.ImageSource>
                    <FontImageSource Glyph="&#xF080;" FontFamily="FontAwesome" Color="{DynamicResource ButtonIconColor}" />
                </Button.ImageSource>
            </Button>
            <Button Text="Exportar Relatório Geral" Command="{Binding ExportarRelatorioGeralCommand}">
                <Button.ImageSource>
                    <FontImageSource Glyph="&#xF56E;" FontFamily="FontAwesome" Color="{DynamicResource ButtonIconColor}" />
                </Button.ImageSource>
            </Button>
            <Button Text="Exportar Relatório Aniversariantes" Command="{Binding ExportarRelatorioAniversariantesCommand}">
                <Button.ImageSource>
                    <FontImageSource Glyph="&#xF56E;" FontFamily="FontAwesome" Color="{DynamicResource ButtonIconColor}" />
                </Button.ImageSource>
            </Button>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
