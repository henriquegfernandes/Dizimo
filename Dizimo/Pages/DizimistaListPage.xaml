<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Dizimo.ViewModels"
             xmlns:local="clr-namespace:Dizimo.Converters"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2021/maui/toolkit"
             xmlns:fonts="clr-namespace:Fonts"
             x:Class="Dizimo.Pages.DizimistaListPage">
    <ContentPage.Resources>
        <ResourceDictionary>
            <local:NullToBoolConverter x:Key="NullToBoolConverter" />
            <local:GreaterThanZeroToBoolConverter x:Key="GreaterThanZeroToBoolConverter" />
            <local:AtivoToStatusConverter x:Key="AtivoToStatusConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>
    <Grid>
        <ScrollView>
            <VerticalStackLayout Spacing="{StaticResource LayoutSpacing}" Padding="{StaticResource LayoutPadding}">
                <Label Text="Dizimistas" FontSize="24" HorizontalOptions="Center" />
                <StackLayout Padding="16" Spacing="12">
                    <!-- Filtro unificado -->
                    <Grid ColumnSpacing="{StaticResource LayoutSpacing}" ColumnDefinitions="*,Auto">
                        <Entry Placeholder="Buscar por nome ou número" 
                               Text="{Binding FiltroNome}" 
                               Grid.Column="0"
                               BackgroundColor="#E0E0E0" 
                               TextColor="#333333" 
                               Completed="OnFiltroCompleted" />
                        <Button Text="Filtrar" 
                                Command="{Binding AplicarFiltrosCommand}" 
                                Grid.Column="1"
                                Padding="16,0"
                                VerticalOptions="Center" />
                    </Grid>
                    <!-- Linha de botões de exportação/importação/modelo e filtro de ativos/inativos -->
                    <Grid ColumnSpacing="{StaticResource LayoutSpacing}" ColumnDefinitions="3*,3*,3*,3*">
                        <StackLayout Orientation="Horizontal" HorizontalOptions="Center" Spacing="12" Margin="0,0,0,8" Grid.Column="0">
                            <Label Text="Mostrar:" VerticalOptions="Center" />
                            <Picker ItemsSource="{Binding StatusOptions}" SelectedItem="{Binding StatusSelecionado}" BackgroundColor="#E0E0E0" />
                        </StackLayout>
                        <Button Text="Exportar Planilha"
                                Command="{Binding ExportarCommand}" 
                                ImageSource="{StaticResource IconExport}" 
                                ToolTipProperties.Text="Exportar Planilha" 
                                CornerRadius="8"
                                Padding="10"
                                Grid.Column="1"
                                HorizontalOptions="Center"
                                VerticalOptions="Center" />
                        <Button Text="Baixar Planilha Modelo"
                                Command="{Binding BaixarModeloCommand}" 
                                ImageSource="{StaticResource IconDownload}" 
                                ToolTipProperties.Text="Baixar Planilha Modelo" 
                                CornerRadius="8"
                                Padding="10"
                                Grid.Column="2"
                                HorizontalOptions="Center"
                                VerticalOptions="Center" />
                        <Button Text="Importar Planilha"
                                Command="{Binding ImportarCommand}" 
                                ImageSource="{StaticResource IconImport}" 
                                ToolTipProperties.Text="Importar Planilha" 
                                CornerRadius="8"
                                Padding="10"
                                Grid.Column="3"
                                HorizontalOptions="Center"
                                VerticalOptions="Center" />
                    </Grid>
                    <!-- Linha de título da lista -->
                    <Grid ColumnSpacing="{StaticResource LayoutSpacing}" ColumnDefinitions="1*,2*,3*,2*,1*,1*" Padding="8">
                        <Label Text="" Grid.Column="0" />
                        <Label Text="Nº Cadastro" Grid.Column="1" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                        <Label Text="Nome" Grid.Column="2" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                        <Label Text="Nascimento" Grid.Column="3" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                        <Label Text="Status" Grid.Column="4" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                        <Label Text="" Grid.Column="5" />
                    </Grid>
                    <!-- Lista paginada com infinite scroll e animação -->
                    <CollectionView x:Name="DizimistasCollectionView"
                                    ItemsSource="{Binding Dizimistas}"
                                    RemainingItemsThreshold="5"
                                    RemainingItemsThresholdReachedCommand="{Binding CarregarMaisDizimistasCommand}"
                                    SelectionMode="Multiple"
                                    SelectionChanged="OnSelectionChanged"
                                    Margin="0,0,0,8">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="{StaticResource LayoutSpacing}" ColumnDefinitions="1*,2*,3*,2*,1*,1*" Padding="8">
                                    <Label Text="{Binding NumeroCadastro}" Grid.Column="1" HorizontalTextAlignment="Center" />
                                    <Label Text="{Binding Nome}" Grid.Column="2" HorizontalTextAlignment="Center" />
                                    <Label Text="{Binding DataNascimento, StringFormat='{0:dd/MM/yyyy}'}" Grid.Column="3" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="4" Text="{Binding Ativo, Converter={StaticResource AtivoToStatusConverter}}" HorizontalTextAlignment="Center" />
                                    <Button Grid.Column="5"
                                            Clicked="OnVerDetalhesDizimistaClicked"
                                            CommandParameter="{Binding .}"
                                            ImageSource="{StaticResource IconEye}"
                                            Padding="0"
                                            CornerRadius="6"
                                            HorizontalOptions="Center"
                                            VerticalOptions="Center"/>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                    <!-- Botões de excluir/inativar -->
                    <StackLayout Orientation="Horizontal" HorizontalOptions="Center" Spacing="12" Margin="0,8,0,0">
                        <Button Text="Excluir" 
                                Command="{Binding ExcluirDizimistasSelecionadosCommand}" 
                                IsVisible="{Binding DizimistasSelecionados.Count, Converter={StaticResource GreaterThanZeroToBoolConverter}}"
                                Padding="12"
                                CornerRadius="8"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"
                                ImageSource="{StaticResource IconTrash}">
                        </Button>
                        <Button Text="Ativar/Inativar" 
                                Command="{Binding InativarDizimistasSelecionadosCommand}" 
                                IsVisible="{Binding DizimistasSelecionados.Count, Converter={StaticResource GreaterThanZeroToBoolConverter}}"
                                Padding="12"
                                CornerRadius="8"
                                HorizontalOptions="Center"
                                VerticalOptions="Center">
                            <Button.ImageSource>
                                <FontImageSource Glyph="&#xE7B0;" FontFamily="{x:Static fonts:FluentUI.FontFamily}" Color="{DynamicResource ButtonIconColor}" />
                            </Button.ImageSource>
                        </Button>
                    </StackLayout>
                </StackLayout>
            </VerticalStackLayout>
        </ScrollView>
        <!-- Botão flutuante de adicionar dizimista -->
        <Button
            Command="{Binding NovoDizimistaCommand}"
            Clicked="OnNovoDizimistaClicked"
            IsEnabled="True"
            ImageSource="{StaticResource IconAdd}"
            CornerRadius="28"
            Padding="0"
            HeightRequest="56"
            WidthRequest="56"
            VerticalOptions="End"
            HorizontalOptions="End"
            Margin="24"
            BackgroundColor="{DynamicResource Primary}"
            TextColor="White"
            FontSize="28"
            SemanticProperties.Description="Adicionar dizimista" />
    </Grid>
</ContentPage>
