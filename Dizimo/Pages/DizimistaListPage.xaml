<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Dizimo.ViewModels"
             xmlns:local="clr-namespace:Dizimo.Converters"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2021/maui/toolkit"
             x:Class="Dizimo.Pages.DizimistaListPage">
    <ContentPage.Resources>
        <ResourceDictionary>
            <local:NullToBoolConverter x:Key="NullToBoolConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>
    <ScrollView>
        <VerticalStackLayout Spacing="{StaticResource LayoutSpacing}" Padding="{StaticResource LayoutPadding}">
            <Label Text="Dizimistas" FontSize="24" HorizontalOptions="Center" />
            <StackLayout Padding="16" Spacing="12">
                <!-- Filtros -->
                <StackLayout Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                    <Entry Placeholder="Buscar por nome" Text="{Binding FiltroNome}" WidthRequest="200" />
                    <Entry Placeholder="Buscar por número" Text="{Binding FiltroNumeroCadastro}" WidthRequest="100" Keyboard="Numeric" />
                    <Button Text="Filtrar" Command="{Binding AplicarFiltrosCommand}" />
                </StackLayout>

                <!-- Linha de botões de exportação/importação/modelo -->
                <StackLayout Orientation="Horizontal" HorizontalOptions="Center" Spacing="24" Margin="0,0,0,12">
                    <Button ImageSource="export.png" Command="{Binding ExportarCommand}" ToolTip="Exportar CSV" BackgroundColor="#E3F2FD" CornerRadius="20">
                        <Button.Triggers>
                            <Trigger TargetType="Button" Property="IsPointerOver" Value="True">
                                <Setter Property="Scale" Value="1.1" />
                                <Setter Property="BackgroundColor" Value="#BBDEFB" />
                            </Trigger>
                        </Button.Triggers>
                    </Button>
                    <Button ImageSource="import.png" Command="{Binding ImportarCommand}" ToolTip="Importar CSV" BackgroundColor="#E8F5E9" CornerRadius="20">
                        <Button.Triggers>
                            <Trigger TargetType="Button" Property="IsPointerOver" Value="True">
                                <Setter Property="Scale" Value="1.1" />
                                <Setter Property="BackgroundColor" Value="#C8E6C9" />
                            </Trigger>
                        </Button.Triggers>
                    </Button>
                    <Button ImageSource="template.png" Command="{Binding BaixarModeloCommand}" ToolTip="Baixar Modelo" BackgroundColor="#FFF3E0" CornerRadius="20">
                        <Button.Triggers>
                            <Trigger TargetType="Button" Property="IsPointerOver" Value="True">
                                <Setter Property="Scale" Value="1.1" />
                                <Setter Property="BackgroundColor" Value="#FFE0B2" />
                            </Trigger>
                        </Button.Triggers>
                    </Button>
                </StackLayout>

                <!-- Lista paginada com infinite scroll e animação -->
                <CollectionView ItemsSource="{Binding Dizimistas}"
                                RemainingItemsThreshold="5"
                                RemainingItemsThresholdReachedCommand="{Binding CarregarMaisDizimistasCommand}"
                                SelectionMode="Single"
                                SelectedItem="{Binding SelectedDizimista, Mode=TwoWay}"
                                Margin="0,0,0,8">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame Padding="12" Margin="0,0,0,12" HasShadow="True" CornerRadius="16" BackgroundColor="#FAFAFA">
                                <Frame.Triggers>
                                    <DataTrigger TargetType="Frame" Binding="{Binding Ativo}" Value="False">
                                        <Setter Property="BackgroundColor" Value="#FFEBEE" />
                                    </DataTrigger>
                                </Frame.Triggers>
                                <StackLayout Orientation="Horizontal" Spacing="16">
                                    <Label Text="{Binding NumeroCadastro}" FontAttributes="Bold" WidthRequest="60" />
                                    <Label Text="{Binding Nome}" FontSize="18" WidthRequest="200" />
                                    <Label Text="{Binding DataNascimento, StringFormat='dd/MM/yyyy'}" WidthRequest="100" />
                                    <Label Text="{Binding Ativo, StringFormat='Ativo: {0}'}" WidthRequest="80" />
                                </StackLayout>
                                <Frame.Behaviors>
                                    <toolkit:AnimationBehavior AnimationType="FadeIn" Duration="400" Delay="100" />
                                </Frame.Behaviors>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </StackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
