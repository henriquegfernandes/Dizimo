<?xml version="1.0" encoding="utf-8"?>
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Dizimo.ViewModels"
             x:Class="Dizimo.Pages.UsuarioCadastroPage"
             x:DataType="vm:UsuarioCadastroViewModel">

    <Grid RowDefinitions="Auto,*" 
          HorizontalAlignment="Stretch" 
          VerticalAlignment="Stretch">
        <!-- Barra de navegação customizada -->
        <Grid Grid.Row="0" Margin="16,12" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
            <!-- Botão de voltar -->
            <Button Grid.Column="0" 
                    Content="Voltar"
                    Command="{Binding VoltarCommand}"
                    Classes="Secondary"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center" />
            
            <!-- Título centralizado -->
            <TextBlock Grid.Column="1" 
                       Text="Cadastro de Usuário" 
                       FontSize="20"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
            
            <!-- Botão de excluir à direita (visível apenas em modo edição) -->
            <Button Grid.Column="2"
                    Content="Excluir"
                    Command="{Binding ExcluirCommand}"
                    Classes="Danger"
                    IsVisible="{Binding IsEditMode}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center" />
        </Grid>

        <!-- Conteúdo da página -->
        <ScrollViewer Grid.Row="1" 
                      Margin="16,12"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto"
                      Padding="0,0,0,40">
            <StackPanel>

                <!-- Formulário -->
                <Grid RowSpacing="12" ColumnSpacing="12" Margin="0,0,0,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Nome -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Nome:" FontWeight="Bold" />
                    <TextBox Grid.Row="0" Grid.Column="0" 
                             Text="{Binding Nome}" 
                             PlaceholderText="Digite o nome"
                             Margin="0,25,0,0"
                             Padding="12,8"
                             CornerRadius="6" />

                    <!-- Login -->
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Login:" FontWeight="Bold" />
                    <TextBox Grid.Row="0" Grid.Column="1" 
                             Text="{Binding Login}" 
                             PlaceholderText="Digite o login"
                             Margin="0,25,0,0"
                             Padding="12,8"
                             CornerRadius="6" />

                    <!-- Tipo de Acesso -->
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Tipo de Acesso:" FontWeight="Bold" />
                    <ComboBox Grid.Row="1" Grid.Column="0" 
                              ItemsSource="{Binding PerfilOptions}"
                              SelectedItem="{Binding PerfilSelecionado}"
                              Margin="0,25,0,0"
                              Padding="12,8"
                              CornerRadius="6" />

                    <!-- Senha -->
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="Senha:" FontWeight="Bold" />
                    <TextBox Grid.Row="1" Grid.Column="1" 
                             Text="{Binding Senha}"
                             PasswordChar="●"
                             PlaceholderText="Digite a senha"
                             Margin="0,25,0,0"
                             Padding="12,8"
                             CornerRadius="6" />

                    <!-- Usuário Ativo -->
                    <Grid Grid.Row="2" Grid.Column="0" ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <TextBlock Grid.Column="0"
                                   Text="Usuário Ativo"
                                   VerticalAlignment="Center" />
                        <ToggleSwitch Grid.Column="1"
                                      IsChecked="{Binding Ativo}"
                                      VerticalAlignment="Center" />
                    </Grid>

                    <!-- Botões -->
                    <Grid Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,12,0,0">
                        <Button Grid.Column="0"
                                Content="Cancelar"
                                Command="{Binding VoltarCommand}"
                                Classes="Secondary"
                                Padding="12"
                                CornerRadius="6"
                                HorizontalAlignment="Center" />
                        
                        <Button Grid.Column="1"
                                Content="Salvar"
                                Command="{Binding SalvarCommand}"
                                Classes="Primary"
                                Padding="12"
                                CornerRadius="6"
                                HorizontalAlignment="Center" />
                    </Grid>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
