<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Dizimo.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:sf="clr-namespace:Syncfusion.Maui.Toolkit.SegmentedControl;assembly=Syncfusion.Maui.Toolkit"
    xmlns:pages="clr-namespace:Dizimo.Pages"
    Shell.FlyoutBehavior="Flyout"
    Title="Dizimo">

    <ShellContent
        Title="Login"
        Icon="login.png"
        ContentTemplate="{DataTemplate pages:LoginPage}"
        Route="login"
        IsVisible="False"/>

    <ShellContent
        Title="Dashboard"
        Icon="{StaticResource IconDashboard}"
        ContentTemplate="{DataTemplate pages:MainPage}"
        Route="main" />

    <ShellContent
        Title="Projects"
        Icon="{StaticResource IconProjects}"
        ContentTemplate="{DataTemplate pages:ProjectListPage}"
        Route="projects" />

    <ShellContent
        Title="Manage Meta"
        Icon="{StaticResource IconMeta}"
        ContentTemplate="{DataTemplate pages:ManageMetaPage}"
        Route="manage" />

    <ShellContent
        Title="Dizimistas"
        Icon="{StaticResource IconPerson}"
        ContentTemplate="{DataTemplate pages:DizimistaListPage}"
        Route="dizimistas" />

    <ShellContent
        Title="Ofertas"
        Icon="{StaticResource IconMoney}"
        ContentTemplate="{DataTemplate pages:OfertaListPage}"
        Route="ofertas" />

    <ShellContent
        Title="Usuários"
        Icon="{StaticResource IconAdmin}"
        ContentTemplate="{DataTemplate pages:UsuarioListPage}"
        Route="usuarios"
        IsVisible="{Binding IsAdmin}" />

    <Shell.FlyoutHeader>
        <StackLayout Padding="15" Orientation="Horizontal" HorizontalOptions="Center" Spacing="10">
            <Image Source="avatar.png" HeightRequest="32" WidthRequest="32" VerticalOptions="Center" />
            <StackLayout>
                <Label Text="Usuário: " FontAttributes="Bold" />
                <Label Text="{Binding UsuarioNome}" />
                <Label Text="{Binding UsuarioPerfil}" FontSize="12" TextColor="Gray" />
            </StackLayout>
        </StackLayout>
    </Shell.FlyoutHeader>

    <Shell.FlyoutFooter>
        <VerticalStackLayout Padding="15" Spacing="10">
            <Grid>
                <StackLayout Orientation="Horizontal" HorizontalOptions="Center" VerticalOptions="Center">
                    <Button Text="Logout" Command="{Binding LogoutCommand}" />
                    <sf:SfSegmentedControl x:Name="ThemeSegmentedControl" 
                        VerticalOptions="Center" HorizontalOptions="Center" SelectionChanged="SfSegmentedControl_SelectionChanged"
                        SegmentWidth="40" SegmentHeight="40">
                        <sf:SfSegmentedControl.ItemsSource>
                            <x:Array Type="{x:Type sf:SfSegmentItem}">
                                <sf:SfSegmentItem ImageSource="{StaticResource IconLight}" SemanticProperties.Description="Light mode"/>
                                <sf:SfSegmentItem ImageSource="{StaticResource IconDark}" SemanticProperties.Description="Dark mode"/>
                            </x:Array>
                        </sf:SfSegmentedControl.ItemsSource>
                    </sf:SfSegmentedControl>
                </StackLayout>
            </Grid>
            <Button Text="Configurar Pasta de Backup" Command="{Binding EscolherPastaCommand}" />
            <Label Text="Pasta atual: {Binding BackupFolderPath}" FontSize="12" />
            <Button Text="Backup para Pasta" Command="{Binding BackupCommand}" />
            <Button Text="Restaurar da Pasta" Command="{Binding RestoreCommand}" />
        </VerticalStackLayout>
    </Shell.FlyoutFooter>

</Shell>
