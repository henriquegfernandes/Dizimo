{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "MAUI: Windows Debug",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/Dizimo/bin/Debug/net10.0-windows10.0.19041.0/win-x64/Dizimo.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/Dizimo",
